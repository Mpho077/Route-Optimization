<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend Task Form: add route optimization fields -->
    <record id="view_task_form_route_optimization" model="ir.ui.view">
        <field name="name">project.task.form.route.optimization</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Route Optimization" name="route_optimization">
                    <field name="route_order"/>
                    <field name="job_category"/>
                    <field name="estimated_duration_hours"/>
                    <field name="overdue_days"/>
                    <field name="is_route_magnet"/>
                    <field name="route_plan_id"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Extend Task List: add route_order column -->
    <record id="view_task_tree_route_optimization" model="ir.ui.view">
        <field name="name">project.task.tree.route.optimization</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='stage_id']" position="before">
                <field name="route_order" string="#" optional="show"/>
                <field name="job_category" optional="hide"/>
                <field name="overdue_days" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
