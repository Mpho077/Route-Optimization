<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Settings form: Route Optimization section -->
    <record id="res_config_settings_view_form_route" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.route.optimization</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Route Optimization" string="Route Optimization"
                     name="route_optimization">

                    <block title="Google Maps" id="google_maps_settings">
                        <setting id="google_maps_api_key_setting"
                                 help="API key with Distance Matrix, Directions, and Geocoding APIs enabled.">
                            <field name="google_maps_api_key" password="True"/>
                        </setting>
                        <setting id="google_maps_base_url_setting"
                                 help="Override the default Google Maps API base URL if needed.">
                            <field name="google_maps_base_url"/>
                        </setting>
                        <setting id="google_maps_test_setting"
                                 help="Verify your Google Maps API key is valid and reachable.">
                            <button name="action_test_connection"
                                    string="Test Connection"
                                    type="object"
                                    class="btn-primary"/>
                        </setting>
                        <setting id="request_timeout_setting"
                                 help="Timeout in seconds for API requests.">
                            <field name="request_timeout"/>
                        </setting>
                    </block>

                    <block title="Optimization Weights" id="optimization_weights">
                        <setting id="distance_penalty_setting"
                                 help="Points deducted per km of driving distance.">
                            <field name="distance_penalty_per_km"/>
                        </setting>
                        <setting id="cluster_bonus_setting"
                                 help="Bonus for tasks sharing the same postal code.">
                            <field name="cluster_bonus"/>
                        </setting>
                        <setting id="overdue_multiplier_setting"
                                 help="Multiplier for the exponential overdue urgency term.">
                            <field name="overdue_multiplier"/>
                        </setting>
                        <setting id="overdue_base_setting"
                                 help="Exponential base (urgency = multiplier x base ^ overdue_days).">
                            <field name="overdue_base"/>
                        </setting>
                        <setting id="critical_overdue_setting"
                                 help="After this many days overdue, the task becomes a mandatory magnet anchor in the route.">
                            <field name="critical_overdue_days"/>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>
</odoo>
